        "delay": 1.0
      },
      {
        "name": "Terminal",
        "command": "kitty",
        "delay": 1.5
      }
    ]
  },
  "Media": {
    "description": "Music and streaming",
    "color": "#8E44AD",
    "apps": [
      {
        "name": "Music",
        "command": "spotify",
        "delay": 0
      },
      {
        "name": "Discord",
        "command": "discord",
        "delay": 2.0
      }
    ]
  },
  "Study-with-Workspace": {
    "description": "Multi-workspace study setup example",
    "color": "#E67E22",
    "apps": [
      {
        "name": "Browser",
        "command": "firefox",
        "delay": 0,
