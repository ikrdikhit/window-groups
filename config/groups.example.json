      {
        "name": "Notes",
        "command": "obsidian",
        "delay": 1.0,
        "workspace": 2
      },
      {
        "name": "Terminal",
        "command": "kitty",
        "delay": 1.5,
        "workspace": 2,
        "pre_command": "mkdir -p ~/notes"
      }
    ]
  }
