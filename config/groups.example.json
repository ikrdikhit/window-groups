      {
        "name": "Editor",
        "command": "code",
        "delay": 1.2
      }
    ]
  },
  "Study": {
    "description": "Study / research session",
    "color": "#27AE60",
    "apps": [
      {
        "name": "Browser",
        "command": "firefox",
        "delay": 0
      },
      {
        "name": "Notes",
